# ──────────────────────────────────────────────
# Provider Selection
# ──────────────────────────────────────────────
# Set LLM_PROVIDER to one of: openai (default), anthropic, gemini, nim, ollama
# The factory falls through providers on connection failure.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# ──────────────────────────────────────────────
# Provider: OpenAI (default — also works with OpenAI-compatible endpoints)
# ──────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_TIMEOUT=60

# ──────────────────────────────────────────────
# Provider: Anthropic (Claude)
# ──────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_TIMEOUT=60

# ──────────────────────────────────────────────
# Provider: Google Gemini
# ──────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL=gemini-1.5-pro
GEMINI_TIMEOUT=60

# ──────────────────────────────────────────────
# Provider: NVIDIA NIM (testing / internal)
# ──────────────────────────────────────────────
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=z-ai/glm-5.1
NIM_TIMEOUT=60

# ──────────────────────────────────────────────
# Provider: Ollama (local CPU fallback)
# ──────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_TIMEOUT=120

# ──────────────────────────────────────────────
# Agent Runtime
# ──────────────────────────────────────────────
GHOST_MOCK_AI=false
GHOST_MAX_RETRIES=3
GHOST_LOG_DIR=logs

# ──────────────────────────────────────────────
# Email (escalation)
# ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=

# ──────────────────────────────────────────────
# Webhook
# ──────────────────────────────────────────────
ESCALATION_WEBHOOK_URL=

# ──────────────────────────────────────────────
# Gumroad (license validation)
# ──────────────────────────────────────────────
GUMROAD_PRODUCT_ID=
GUMROAD_ACCESS_TOKEN=

# ──────────────────────────────────────────────
# Telegram bot (optional)
# ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
